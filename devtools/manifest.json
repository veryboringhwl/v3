{
  "manifest_version": 3,
  "name": "Spicetify Developer Tools",
  "description": "Adds deobfuscated class names to the CEF Developer Tools.",
  "version": "1.0.0",
  "minimum_chrome_version": "145",
  "devtools_page": "main.html",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["main.html", "panel.html", "build/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
